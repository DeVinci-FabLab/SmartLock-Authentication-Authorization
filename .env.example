# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=smartlock
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_URL=your_keycloak_url_here
KEYCLOAK_REALM=master

# Service account smartlock-api (client credentials)
# Get the secret from: Keycloak → Clients → smartlock-api → Credentials tab
KEYCLOAK_CLIENT_ID=smartlock-api

KEYCLOAK_CLIENT_SECRET=your_client_secret_here
LOCKER_CLIENT_SECRET=your_client_secret_here
NFC_CLIENT_SECRET=your_client_secret_here