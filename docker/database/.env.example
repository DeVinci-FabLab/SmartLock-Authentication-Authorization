POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=smartlock

# Literal URL — no variable interpolation in Docker env_file
DATABASE_URL=postgresql://username:password@postgres:5432/smartlock

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Keycloak — copy values from your root .env
# -----------------------------------------------------------------------------
KEYCLOAK_URL=your_keycloak_url_here
KEYCLOAK_REALM=your_realm_here
KEYCLOAK_CLIENT_ID=smartlock-api
KEYCLOAK_CLIENT_SECRET=your_client_secret_here
LOCKER_CLIENT_SECRET=your_locker_client_secret_here
NFC_CLIENT_SECRET=your_nfc_client_secret_here

